{
  "$schema": "https://design-tokens.org/schema",
  "meta": {
    "name": "Savadanko Brand Concept",
    "version": "1.0.0",
    "description": "Design tokens extracted from savadanko-web. Refined dark portfolio aesthetic with purple primary and cyan→purple signature gradient.",
    "source": "https://github.com/SaveliyDanko/savadanko-web"
  },

  "color": {
    "brand": {
      "primary":      { "value": "#8b5cf6", "description": "Main brand color — violet-500. Used for CTAs, focus rings, key accents." },
      "primaryLight": { "value": "#a78bfa", "description": "Hover state, lighter violet for gradients." },
      "primaryDark":  { "value": "#7c3aed", "description": "Pressed state, deeper violet." },
      "accentCyan":   { "value": "#06b6d4", "description": "Signature gradient start — used in cyan→purple brand gradient (logo, preloader)." },
      "accentGreen":      { "value": "#34d399", "description": "Success/positive accent." },
      "accentGreenDark":  { "value": "#059669" },
      "sectionLabel":     { "value": "#6f87ff", "description": "Periwinkle blue — section labels, active states, decorative glows." }
    },

    "surface": {
      "dark": {
        "base":     { "value": "#010105", "description": "Page background — near-black with slight blue undertone." },
        "raised":   { "value": "#111113", "description": "Cards, header glass." },
        "higher":   { "value": "#1a1a1f", "description": "Hover surfaces, dropdowns." },
        "card":     { "value": "#0f0f13" }
      },
      "light": {
        "base":     { "value": "#fafbfe" },
        "raised":   { "value": "#f0f1f6" },
        "higher":   { "value": "#e6e8f0" },
        "card":     { "value": "#f4f5fa" }
      }
    },

    "text": {
      "dark": {
        "heading":          { "value": "#ffffff" },
        "body":             { "value": "#f0f0f3", "description": "Primary readable text." },
        "bodySecondary":    { "value": "#656c89", "description": "Paragraph body color." },
        "muted":            { "value": "#71717a", "description": "Captions, helper text." },
        "tertiary":         { "value": "#4f5672" }
      },
      "light": {
        "heading":          { "value": "#111827" },
        "body":             { "value": "#1e2030" },
        "bodySecondary":    { "value": "#64748b" },
        "muted":            { "value": "#64748b" },
        "tertiary":         { "value": "#94a3b8" }
      }
    },

    "border": {
      "dark": {
        "default":  { "value": "#1e1e24" },
        "strong":   { "value": "#27272a" },
        "card":     { "value": "rgba(255, 255, 255, 0.04)" },
        "input":    { "value": "rgba(255, 255, 255, 0.08)" }
      },
      "light": {
        "default":  { "value": "#d4d8e8" },
        "strong":   { "value": "#c0c6d8" },
        "card":     { "value": "#e2e5f0" },
        "input":    { "value": "#d4d8e8" }
      }
    }
  },

  "gradient": {
    "brand": {
      "value": "linear-gradient(135deg, #06b6d4 0%, #8b5cf6 100%)",
      "description": "Signature cyan→purple gradient. Used for logo mark, preloader, key brand moments. Use sparingly."
    },
    "primaryButton": {
      "value": "linear-gradient(90deg, #8b5cf6 0%, #7c3aed 100%)"
    },
    "heroHeadline": {
      "value": "linear-gradient(135deg, #a78bfa 0%, #c084fc 50%, #8b5cf6 100%)",
      "description": "Animated shimmer gradient for hero text — bg-clip: text."
    },
    "stat": {
      "value": "linear-gradient(90deg, #9fb5ff 0%, #a78bfa 50%, #8b5cf6 100%)",
      "description": "Used for animated stat numbers."
    },
    "scrollProgress": {
      "value": "linear-gradient(90deg, #8b5cf6, #6f87ff, #a78bfa)"
    }
  },

  "typography": {
    "fontFamily": {
      "sans": {
        "value": "\"Inter\", ui-sans-serif, system-ui, -apple-system, sans-serif",
        "description": "Primary UI font. Use weights 400, 500, 600, 700."
      },
      "mono": {
        "value": "\"JetBrains Mono\", ui-monospace, \"SF Mono\", Menlo, monospace",
        "description": "Code, technical labels, version numbers."
      }
    },
    "fontWeight": {
      "regular":  { "value": 400 },
      "medium":   { "value": 500 },
      "semibold": { "value": 600 },
      "bold":     { "value": 700 }
    },
    "scale": {
      "xs":   { "value": "0.75rem",  "lineHeight": "1rem",     "description": "12 / 16 — captions, micro-labels." },
      "sm":   { "value": "0.875rem", "lineHeight": "1.25rem",  "description": "14 / 20 — UI labels, buttons." },
      "base": { "value": "1rem",     "lineHeight": "1.5rem",   "description": "16 / 24 — body text." },
      "lg":   { "value": "1.125rem", "lineHeight": "1.75rem",  "description": "18 / 28 — lead paragraphs." },
      "xl":   { "value": "1.25rem",  "lineHeight": "1.75rem" },
      "2xl":  { "value": "1.5rem",   "lineHeight": "2rem" },
      "3xl":  { "value": "1.875rem", "lineHeight": "2.25rem", "description": "30 — section H2." },
      "4xl":  { "value": "2.25rem",  "lineHeight": "2.5rem",  "description": "36 — section H2 large viewport." },
      "5xl":  { "value": "3rem",     "lineHeight": "1" },
      "7xl":  { "value": "4.5rem",   "lineHeight": "1.1",     "description": "Hero — mobile." },
      "8xl":  { "value": "6rem",     "lineHeight": "1.1",     "description": "Hero — sm." },
      "9xl":  { "value": "8rem",     "lineHeight": "1.1",     "description": "Hero — lg+." }
    },
    "letterSpacing": {
      "tight":  { "value": "-0.025em", "description": "Headings — tighten for confidence." },
      "normal": { "value": "0em" },
      "wide":   { "value": "0.04em",   "description": "Uppercase micro-labels." }
    }
  },

  "spacing": {
    "description": "8-point base. Use Tailwind scale: 0.25rem increments.",
    "0":   { "value": "0" },
    "1":   { "value": "0.25rem" },
    "2":   { "value": "0.5rem" },
    "3":   { "value": "0.75rem" },
    "4":   { "value": "1rem" },
    "5":   { "value": "1.25rem" },
    "6":   { "value": "1.5rem",  "description": "Default container side padding." },
    "8":   { "value": "2rem" },
    "10":  { "value": "2.5rem" },
    "12":  { "value": "3rem",    "description": "Block separation." },
    "16":  { "value": "4rem" },
    "20":  { "value": "5rem",    "description": "Section vertical padding (mobile)." },
    "28":  { "value": "7rem",    "description": "Section vertical padding (sm+)." }
  },

  "layout": {
    "containerMaxWidth": { "value": "72rem", "description": "max-w-6xl = 1152px. Sole content container." },
    "containerPadding":  { "value": "1.5rem", "description": "px-6 — applied at every breakpoint." },
    "sectionPaddingY":   { "value": "5rem 7rem", "description": "py-20 mobile → sm:py-28." }
  },

  "radius": {
    "sm":   { "value": "0.375rem", "description": "Tight radius — small chips." },
    "md":   { "value": "0.5rem",   "description": "Default for inputs." },
    "lg":   { "value": "0.5rem",   "description": "Buttons (rounded-lg)." },
    "xl":   { "value": "0.75rem" },
    "2xl":  { "value": "1rem",     "description": "Cards, pill tiles." },
    "3xl":  { "value": "1.5rem" },
    "full": { "value": "9999px",   "description": "Pills, badges, primary CTA." }
  },

  "shadow": {
    "card":            { "value": "inset 0 1px 0 rgba(255, 255, 255, 0.02)" },
    "cardHover":       { "value": "0 10px 24px rgba(99, 102, 241, 0.14)" },
    "cardFeatured":    { "value": "inset 0 0 0 1px rgba(58, 92, 184, 0.08), 0 0 0 1px rgba(25, 37, 77, 0.18)" },
    "primaryButton":   { "value": "0 10px 25px -5px rgba(139, 92, 246, 0.25), 0 8px 10px -6px rgba(139, 92, 246, 0.25)" },
    "primaryButtonHover": { "value": "0 0 30px rgba(139, 92, 246, 0.4)" },
    "menu":            { "value": "0 28px 90px rgba(2, 6, 23, 0.52)" },
    "glowSoft":        { "value": "0 0 24px rgba(111, 141, 253, 0.15)" }
  },

  "blur": {
    "header":    { "value": "12px", "description": "backdrop-blur-md on sticky header." },
    "menu":      { "value": "40px", "description": "backdrop-blur-2xl on side menu." },
    "glowLarge": { "value": "120px", "description": "Decorative blur halos in hero." }
  },

  "motion": {
    "easing": {
      "out":     { "value": "cubic-bezier(0.16, 1, 0.3, 1)", "description": "Default for entrances." },
      "linear":  { "value": "linear" },
      "spring":  { "value": "type:spring stiffness:400 damping:17", "description": "Framer Motion config for buttons." }
    },
    "duration": {
      "fast":   { "value": "150ms", "description": "Hover color/border changes." },
      "base":   { "value": "200ms", "description": "Most interactions." },
      "medium": { "value": "300ms", "description": "Menu open/close." },
      "slow":   { "value": "500ms", "description": "Theme transitions, hero reveals." },
      "scenic": { "value": "1200ms", "description": "Count-up animations." }
    },
    "keyframes": {
      "shimmer":      { "duration": "6s",  "easing": "ease-in-out", "loop": "infinite", "description": "Background-position animation for gradient text." },
      "marqueeLeft":  { "duration": "28s", "easing": "linear",      "loop": "infinite" },
      "marqueeRight": { "duration": "28s", "easing": "linear",      "loop": "infinite" },
      "orbitSpin":    { "duration": "auto", "easing": "linear",     "loop": "infinite", "description": "Used by OrbitingSkills." },
      "preloader":    { "duration": "1.8s", "easing": "ease-in-out", "loop": "infinite", "description": "Pulse on logo SVG." }
    }
  },

  "breakpoint": {
    "sm": { "value": "640px" },
    "md": { "value": "768px" },
    "lg": { "value": "1024px" },
    "xl": { "value": "1280px" }
  },

  "zIndex": {
    "base":     { "value": 0 },
    "elevated": { "value": 10 },
    "header":   { "value": 50 },
    "menu":     { "value": 60 },
    "modal":    { "value": 100 },
    "preloader":{ "value": 9999 }
  }
}
