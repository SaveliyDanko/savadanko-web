# Generate with: node -e "const b=await import('bcryptjs');console.log(await b.hash('yourpassword',12))"
ADMIN_PASSWORD_HASH=$2b$12$...

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-secret-here

PORT=3001

# Absolute path to the site root (where package.json and src/ live)
SITE_DIR=/var/www/savadanko
